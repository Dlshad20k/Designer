<script>
const STORAGE_KEY='dh_designer_projects';
function getProjects(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]')}catch{return[]}}
function saveProjects(a){localStorage.setItem(STORAGE_KEY,JSON.stringify(a))}

const pid=new URLSearchParams(location.search).get('id');
let proj=null,curIdx=0;

function init(){
  if(!pid){show('not-found');return}
  const all=getProjects();
  proj=all.find(p=>p.id===pid);
  if(!proj){show('not-found');return}
  // Track view
  proj.views=(proj.views||0)+1;
  const i=all.findIndex(p=>p.id===pid);
  if(i>-1){all[i]=proj;saveProjects(all)}
  render();
}

function show(id){document.getElementById(id).style.display='block'}

function render(){
  document.title=`${proj.name} — DH Designer`;
  show('hero');
  document.getElementById('hero-title').textContent=proj.name;
  const tags=document.getElementById('hero-tags');
  const date=new Date(proj.created).toLocaleDateString('de-DE',{day:'2-digit',month:'long',year:'numeric'});
  tags.innerHTML=`
    <span class="hero-tag">${proj.category}</span>
    ${proj.client?`<span class="hero-tag">${proj.client}</span>`:''}
    <span class="hero-tag date">${date}</span>
    <span class="hero-tag date">${proj.files.length} Datei${proj.files.length!==1?'en':''}</span>`;

  document.getElementById('main-content').style.display='grid';
  setStatus(proj.status);

  if(proj.note){
    const nb=document.getElementById('note-box');
    nb.textContent='📌 '+proj.note;nb.style.display='block';
  }

  renderGallery(0);
  renderDl();

  // File selector
  const sel=document.getElementById('fb-file-ref');
  proj.files.forEach(f=>{
    const o=document.createElement('option');
    o.value=f.name;o.textContent=f.name;sel.appendChild(o);
  });

  if(proj.status==='approved')showApproved();
  if(proj.status==='changes'&&proj.feedback?.length)showFbSent();
}

// GALLERY
function renderGallery(idx){
  curIdx=idx;
  const f=proj.files[idx];
  const v=document.getElementById('gallery-viewer');

  if(f.type.startsWith('image/')){
    v.innerHTML=`<img src="${f.data}" alt="${f.name}" style="width:100%;height:auto;max-height:600px;object-fit:contain;display:block">`;
  } else {
    const ext=f.name.split('.').pop().toUpperCase();
    v.innerHTML=`<div class="doc-ph">
      <div class="d-icon">📄</div>
      <div class="d-name">${f.name}</div>
      <div class="d-sub">${ext} — Lade die Datei herunter zum Anzeigen</div>
    </div>`;
  }

  document.getElementById('nav-prev').classList.toggle('hidden',idx===0);
  document.getElementById('nav-next').classList.toggle('hidden',idx===proj.files.length-1);

  const counter=document.getElementById('gal-counter');
  if(proj.files.length>1){counter.textContent=`${idx+1} / ${proj.files.length}`}
  else counter.style.display='none';

  // Thumbs
  const thumbs=document.getElementById('thumbs');
  if(proj.files.length>1){
    thumbs.innerHTML=proj.files.map((f2,i)=>{
      if(f2.type.startsWith('image/')){
        return `<img class="thumb ${i===idx?'active':''}" data-idx="${i}" src="${f2.data}" alt="${f2.name}">`;
      }
      const ext2=f2.name.split('.').pop().toUpperCase();
      return `<div class="thumb-doc ${i===idx?'active':''}" data-idx="${i}"><span>📄</span>${ext2}</div>`;
    }).join('');
    thumbs.querySelectorAll('[data-idx]').forEach(el=>{
      el.addEventListener('click',()=>renderGallery(parseInt(el.dataset.idx)));
    });
  }
}

function nav(d){
  const ni=curIdx+d;
  if(ni>=0&&ni<proj.files.length)renderGallery(ni);
}

// DOWNLOADS
function renderDl(){
  const list=document.getElementById('dl-list');
  list.innerHTML=proj.files.map((f,i)=>{
    const ext=f.name.split('.').pop().toLowerCase();
    const icon=f.type.startsWith('image/')?'🖼':ext==='pdf'?'📑':ext==='ai'||ext==='eps'?'✏':'📄';
    const size=fmtSize(f.size);
    return `<div class="dl-item" onclick="dlFile(${i})">
      <span class="dl-icon">${icon}</span>
      <div class="dl-info">
        <div class="dl-name">${f.name}</div>
        ${size?`<div class="dl-size">${size}</div>`:''}
      </div>
      <div class="dl-btn">↓ Download</div>
    </div>`;
  }).join('');

  // Hide "all" button if only one file
  if(proj.files.length<=1)document.getElementById('dl-all-btn').style.display='none';
}

function dlFile(idx){
  const f=proj.files[idx];
  const a=document.createElement('a');
  a.href=f.data;a.download=f.name;a.click();
  showToast(`↓ ${f.name}`);
}

function downloadAll(){
  proj.files.forEach((f,i)=>{
    setTimeout(()=>{
      const a=document.createElement('a');
      a.href=f.data;a.download=f.name;a.click();
    },i*400);
  });
  showToast(`↓ ${proj.files.length} Dateien werden heruntergeladen`);
}

function fmtSize(b){
  if(!b)return'';
  if(b<1024)return b+'B';
  if(b<1048576)return(b/1024).toFixed(0)+'KB';
  return(b/1048576).toFixed(1)+'MB';
}

// APPROVE
function approve(){
  update({status:'approved'});showApproved();showToast('✓ Design freigegeben!');
}
function showApproved(){
  document.getElementById('action-area').style.display='none';
  document.getElementById('suc-approve').classList.add('show');
  setStatus('approved');
}

// FEEDBACK
function toggleFbForm(){
  document.getElementById('fb-form').classList.toggle('open');
}
function sendFb(){
  const txt=document.getElementById('fb-text').value.trim();
  if(!txt){showToast('⚠ Bitte Feedback eingeben');return}
  const fileRef=document.getElementById('fb-file-ref').value;
  const fb={id:Date.now(),type:'changes',message:txt,fileRef:fileRef||null,time:new Date().toISOString()};
  const newFbs=[...(proj.feedback||[]),fb];
  update({status:'changes',feedback:newFbs});
  showFbSent();showToast('✉ Feedback gesendet!');
}
function showFbSent(){
  document.getElementById('action-area').style.display='none';
  document.getElementById('suc-fb').classList.add('show');
  setStatus('changes');
}

// HELPERS
function setStatus(s){
  const el=document.getElementById('status-bar');
  el.className='status-bar '+s;
  el.textContent=s==='approved'?'✓ Freigegeben':s==='changes'?'✎ Änderungen angefragt':'◌ Ausstehende Freigabe';
}
function update(changes){
  Object.assign(proj,changes);
  const all=getProjects();
  const i=all.findIndex(p=>p.id===pid);
  if(i>-1){all[i]=proj;saveProjects(all)}
}
function showToast(msg){
  const t=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2800);
}

init();
</script>

